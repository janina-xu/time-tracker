generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Record {
  id        Int      @id @default(autoincrement())
  category  String
  startTime String
  endTime   String?
  note      String?
  date      String
  createdAt DateTime @default(now())
}